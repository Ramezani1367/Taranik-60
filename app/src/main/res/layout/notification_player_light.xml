<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notification_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFF5F5FA"
    android:padding="12dp">

    <!-- Track Info + Cover Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <!-- ✅ Cover Art -->
        <ImageView
            android:id="@+id/iv_cover"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music_note"
            android:layout_marginEnd="12dp"
            android:background="#FFE8E8F0"
            android:contentDescription="کاور آلبوم" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF1A1A2E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF555570"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>
    </LinearLayout>

    <!-- ✅ Lyrics Section -->
    <LinearLayout
        android:id="@+id/lyrics_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFE8E8F0"
        android:padding="10dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_lyric_line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF1A1A2E"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2" />

        <TextView
            android:id="@+id/tv_lyric_translation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF5C4FC0"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_marginTop="3dp"
            android:lineSpacingMultiplier="1.2" />

    </LinearLayout>

    <!-- Media Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageButton
            android:id="@+id/btn_prev"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_skip_previous"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="قبلی"
            android:tint="#FF555570" />

        <ImageButton
            android:id="@+id/btn_play_pause"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_pause"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="پخش/مکث"
            android:tint="#FF5C4FC0" />

        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_skip_next"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="بعدی"
            android:tint="#FF555570" />

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_close"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="بستن"
            android:tint="#FFAAAA88" />

    </LinearLayout>

</LinearLayout>
